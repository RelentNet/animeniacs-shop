# Database
DATABASE_URL=postgres://animeniacs:animeniacs@localhost:5432/animeniacs

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# better-auth (Phase 15 — replaces Logto). Email + password, sessions in Postgres.
# BETTER_AUTH_SECRET is REQUIRED. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Optional; defaults to NEXT_PUBLIC_SITE_URL when unset.
BETTER_AUTH_URL=

# Square (Phase 3)
# Get sandbox keys from https://developer.squareup.com/apps → your app → Sandbox.
# Webhook signature key is set when you create a webhook subscription
# (Phase 3 Task 13 covers this).
SQUARE_ENV=sandbox
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Art-protection proxy (/api/art): caps the LONGEST edge (width or height) of
# every served product image, protecting portrait + landscape. Default 2048
# ("Facebook standard"); lower = stronger theft protection. Clamped to 256–4096.
ART_IMAGE_MAX_EDGE=2048

# Resend (Phase 9)
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# SMS notifications via sms-edge (Phase 7 → corrected Phase 7.5).
# Endpoint: POST {SMSEDGE_BASE_URL}/sms
# Auth: Authorization: Bearer {SMSEDGE_TOKEN}
# Tenant: animeniacs (create via sms-edge dashboard).
# Token is per-tenant; recorded one-time; cannot be retrieved later.
SMSEDGE_TOKEN=
SMSEDGE_BASE_URL=https://sms-edge.relentnet.dev

# Plausible analytics — runs on shared relentnet infrastructure.
# Set to the script URL on your central Plausible (e.g.
# https://analytics.relentnet.com/js/script.js). Leave empty to
# disable analytics in development. The <script> tag is rendered
# server-side in the root layout when this is set.
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=animeniacs.shop

# Discord (Phase 9)
DISCORD_ORDER_WEBHOOK_URL=

# TaxJar (Phase 15 — admin-toggled)
TAXJAR_API_KEY=

# Phase 10 — abandoned-cart recovery emails + cron
# RESEND_API_KEY is set above (Resend section). The cron sweep additionally needs:
# RESEND_FROM_EMAIL — a verified Resend sender, e.g. orders@animeniacs.shop
# CRON_SECRET — shared secret the cron trigger sends as the x-cron-secret header
#   (generate: openssl rand -hex 32)
# ABANDONED_CART_THRESHOLD_MINUTES — only carts older than this are swept (default 60)
RESEND_FROM_EMAIL=
CRON_SECRET=
ABANDONED_CART_THRESHOLD_MINUTES=60

# Comma-separated emails granted admin without a DB write (the Postgres is
# internal to Coolify, so grant-admin cannot run from a workstation). Empty = disabled.
# ADMIN_EMAILS=you@example.com
