# Plausible config (loaded by the plausible service via env_file)
# Secrets like SECRET_KEY_BASE come from .env.local via docker-compose env interpolation.
# NOTE: First-run admin account creation + site registration (animeniacs.shop)
# is a manual browser step, deferred to Phase 10 when the tracking script is wired up.
BASE_URL=http://localhost:8000
DISABLE_REGISTRATION=invite_only
LISTEN_IP=0.0.0.0
DATABASE_URL=postgres://animeniacs:animeniacs@postgres:5432/plausible
CLICKHOUSE_DATABASE_URL=http://plausible-clickhouse:8123/plausible_events_db
